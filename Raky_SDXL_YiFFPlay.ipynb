   "source": [
    "WEB_URL = 'https://art.kxd.es'\n",
    "API_PORT = 7860\n",
    "\n",
    "import io, base64, threading, time, re, subprocess, gc, os, sys\n",
    "import requests\n",
    "from fastapi import FastAPI\n",
    "import uvicorn, torch\n",
    "from PIL import Image\n",
    "from diffusers import StableDiffusionXLPipeline\n",
    "\n",
    "# 🥷 TRUCO NINJA: Ofuscamos torchao pasivamente para obligar a Diffusers a usar PyTorch puro\n",
    "sys.modules['torchao'] = None\n",
    "\n",
    "app_api = FastAPI()\n",
    "generation_lock = threading.Lock()\n",
    "\n",
    "# 📌 Registro local inalterable de rutas de archivos\n",
    "MODEL_PATH = '/content/models/sdxl_model.safetensors'\n",
    "LORA_REGISTRY = {\n",
    "    'zonkpunch_base': '/content/loras/zonkpunch_base.safetensors',\n",
    "    'zonkpunch_1':    '/content/loras/zonkpunch_1.safetensors',\n",
    "    'zonkpunch_2':    '/content/loras/zonkpunch_2.safetensors',\n",
    "    'zonkpunch_3':    '/content/loras/zonkpunch_3.safetensors',\n",
    "    'zonkpunch_4':    '/content/loras/zonkpunch_4.safetensors',\n",
    "    'zonkpunch_5':    '/content/loras/zonkpunch_5.safetensors',\n",
    "    'zonkpunch_6':    '/content/loras/zonkpunch_6.safetensors',\n",
    "    'zcik':           '/content/loras/zcik.safetensors',\n",
    "    'danziEngine':    '/content/loras/danzi_engine.safetensors',\n",
    "    'edjit':          '/content/loras/edjit.safetensors',\n",
    "    'dagasi':         '/content/loras/dagasi.safetensors',\n",
    "}\n",
    "\n",
    "# 🔧 Inicialización segura del modelo base SDXL en la GPU\n",
    "if 'pipe' not in globals():\n",
    "    print('🔧 Cargando modelo base SDXL nativo en la GPU...')\n",
    "    pipe = StableDiffusionXLPipeline.from_single_file(MODEL_PATH, torch_dtype=torch.float16, use_safetensors=True).to('cuda')\n",
    "    print('✅ Modelo base cargado y listo en VRAM')\n",
    "\n",
    "def limpiar_loras_vram():\n",
    "    \"\"\"🧹 Deshace la fusión de forma rápida y segura sin congelar el hilo principal\"\"\"\n",
    "    try:\n",
    "        pipe.unfuse_lora()\n",
    "        pipe.disable_lora()\n",
    "        # Borramos los adaptadores por su nombre clave de forma nativa para evitar bloqueos\n",
    "        for adapter in list(pipe.get_active_adapters()):\n",
    "            pipe.delete_adapters(adapter)\n",
    "    except Exception:\n",
    "        pass\n",
    "    gc.collect()\n",
    "    torch.cuda.empty_cache()\n",
    "\n",
    "def run_inference(job_dict):\n",
    "    with generation_lock:\n",
    "        limpiar_loras_vram()\n",
    "        \n",
    "        lora_weights = job_dict.get('loraWeights') or {}\n",
    "        prompt_text = (job_dict.get('prompt') or '').lower()\n",
    "        \n",
    "        loras_a_cargar = []\n",
    "        \n",
    "        # 📌 COMPROBACIÓN INTELIGENTE DE ZONKPUNCH (Carga Base + Pack)\n",
    "        if 'zonkpunch' in lora_weights and lora_weights['zonkpunch'] > 0:\n",
    "            peso_val = float(lora_weights['zonkpunch'])\n",
    "            \n",
    "            if os.path.exists(LORA_REGISTRY['zonkpunch_base']):\n",
    "                loras_a_cargar.append((LORA_REGISTRY['zonkpunch_base'], \"zp_base\", peso_val))\n",
    "                \n",
    "            if 'zonkpunch' in prompt_text:\n",
    "                print('  🔮 Palabra \"zonkpunch\" detectada. Preparando Pack 4 + Base...')\n",
    "                target_pack = LORA_REGISTRY['zonkpunch_4']\n",
    "            else:\n",
    "                print('  🔮 Mapeando Pack 1 Predeterminado + Base...')\n",
    "                target_pack = LORA_REGISTRY['zonkpunch_1']\n",
    "                \n",
    "            if os.path.exists(target_pack):\n",
    "                loras_a_cargar.append((target_pack, \"zp_pack\", peso_val))\n",
    "        else:\n",
    "            # Carga normal para el resto de artistas independientes\n",
    "            for name, weight in lora_weights.items():\n",
    "                if name in LORA_REGISTRY and weight and weight > 0:\n",
    "                    loras_a_cargar.append((LORA_REGISTRY[name], \"estilo_unico\", float(weight)))\n",
    "                    break\n",
    "                    \n",
    "        # 🚀 FUSIÓN MULTI-LORA MATEMÁTICA EN LA GPU\n",
    "        if loras_a_cargar:\n",
    "            try:\n",
                for path, adapter_name, _ in loras_a_cargar:\n",
    "                    pipe.load_lora_weights(path, adapter_name=adapter_name)\n",
    "                \n",
    "                nombres = [item[1] for item in loras_a_cargar]\n",
    "                pesos = [item[2] for item in loras_a_cargar]\n",
    "                \n",
    "                pipe.fuse_lora(adapter_names=nombres, lora_scale=1.0, adapter_weights=pesos)\n",
    "                print(f\"  ✅ ¡Doble inyección completada con éxito! Adaptadores fusionados: {nombres}\")\n",
    "            except Exception as e:\n",
    "                print(f\"  ❌ Error aplicando la combinación de LoRAs: {e}\")\n",
    "\n",
    "        seed = job_dict.get('seed')\n",
    "        if seed is None: seed = int(torch.randint(0, 2**32, (1,)).item())\n",
    "        gen = torch.Generator('cuda').manual_seed(seed)\n",
    "\n",
    "        start_time = time.time()\n",
    "        def timeout_callback(pipe_obj, step, timestep, callback_kwargs):\n",
    "            if (time.time() - start_time) > 50.0:\n",
    "                raise TimeoutError(\"⚠️ Límite superado.\")\n",
    "            return callback_kwargs\n",
    "\n",
    "        try:\n",
    "            with torch.autocast('cuda'):\n",
    "                result = pipe(\n",
    "                    prompt=job_dict.get('prompt', ''),\n",
    "                    negative_prompt=job_dict.get('negativePrompt') or 'nsfw, blurry, low quality, deformed',\n",
    "                    width=job_dict.get('width', 1024),\n",
    "                    height=job_dict.get('height', 1024),\n",
    "                    num_inference_steps=job_dict.get('steps', 30),\n",
    "                    guidance_scale=job_dict.get('cfgScale', 7.0),\n",
    "                    generator=gen,\n",
    "                    callback_on_step_end=timeout_callback\n",
    "                )\n",
    "            img_out = result.images[0]\n",
    "        except TimeoutError as te:\n",
    "            print(f'\\n❌ {te}')\n",
    "            raise te\n",
    "        finally:\n",
    "            limpiar_loras_vram()\n",
    "\n",
    "        return img_out, seed\n",
    "\n",
    "# Servidor FastAPI en segundo plano\n",
    "threading.Thread(target=lambda: uvicorn.run(app_api, host='0.0.0.0', port=API_PORT, log_level='warning'), daemon=True).start()\n",
    "time.sleep(2)\n",
    "\n",
    "print('🌐 Creando túnel Cloudflare...')\n",
    "cf_proc = subprocess.Popen(['cloudflared', 'tunnel', '--url', f'http://localhost:{API_PORT}', '--no-autoupdate'], stdout=subprocess.PIPE, stderr=subprocess.STDOUT, universal_newlines=True)\n",
    "\n",
    "TUNNEL_URL = None\n",
    "for _ in range(120):\n",
    "    line = cf_proc.stdout.readline()\n",
    "    match = re.search(r'https://[\\w-]+\\.trycloudflare\\.com', line)\n",
    "    if match: \n",
    "        TUNNEL_URL = match.group(0) \n",
    "        break\n",
    "if not TUNNEL_URL: raise RuntimeError('Error al abrir el túnel.')\n",
    "\n",
    "SESSION_ID = None\n",
    "try:\n",
    "    resp = requests.post(f'{WEB_URL}/api/sessions/register', json={'tunnelUrl': TUNNEL_URL}, timeout=15)\n",
    "    resp.raise_for_status()\n",
    "    SESSION_ID = resp.json()['id']\n",
    "    sync_ok = True\n",
    "except Exception as e:\n",
    "    sync_ok = False\n",
    "    sync_error = str(e)\n",
    "\n",
    "print('\\n' + '━' * 52)\n",
    "if sync_ok:\n",
    "    print(f'✅ SINCRONIZADO VIA DOUBLE-FUSION — GPU activa en art.kxd.es\\n Sesión #{SESSION_ID}')\n",
    "else:\n",
    "    print(f'⚠️ Error de conexión: {sync_error}\\nEnlace manual:')\n",
    "print(f' {TUNNEL_URL}\\n' + '━' * 52)\n",
    "\n",
    "HEADERS = {'Content-Type': 'application/json'}\n",
    "start = time.time()\n",
    "try:\n",
    "    print(\"📡 Escuchando peticiones de la cola web...\")\n",
    "    while time.time() - start < 12 * 3600:\n",
    "        try:\n",
    "            r = requests.get(f'{WEB_URL}/api/internal/next-job', params={'sessionId': SESSION_ID}, headers=HEADERS, timeout=10)\n",
    "            r.raise_for_status()\n",
    "            job = r.json().get('job')\n",
    "        except Exception:\n",
    "            time.sleep(3)\n",
    "            continue\n",
    "        if not job:\n",
    "            time.sleep(3)\n",
    "            continue\n",
    "\n",
    "        jid = job['id']\n",
    "        w, h, s = job.get('width', 1024), job.get('height', 1024), job.get('steps', 30)\n",
    "        print(f'\\n🎨 {jid[:8]}… | {w}×{h} | {s} pasos')\n",
    "        \n",
    "        try:\n",
    "            t0 = time.time()\n",
    "            img_obj, seed = run_inference(job)\n",
    "            print(f' ✓ {time.time()-t0:.1f}s seed={seed}')\n",
    "            buf = io.BytesIO()\n",
    "            img_obj.save(buf, format='JPEG', quality=80)\n",
    "            img_b64 = base64.b64encode(buf.getvalue()).decode()\n",
    "            try:\n",
    "                requests.post(f'{WEB_URL}/api/internal/job-complete', headers=HEADERS, timeout=60, json={'jobId': jid, 'sessionId': SESSION_ID, 'imageBase64': img_b64, 'seed': seed}).raise_for_status()\n",
    "            except requests.exceptions.HTTPError as http_err:\n",
    "                if http_err.response is not None and http_err.response.status_code == 413:\n",
    "                    img_resized = img_obj.resize((512, 512), Image.Resampling.LANCZOS)\n",
    "                    buf_small = io.BytesIO()\n",
    "                    img_resized.save(buf_small, format='JPEG', quality=50)\n",
    "                    img_b64_small = base64.b64encode(buf_small.getvalue()).decode()\n",
    "                    requests.post(f'{WEB_URL}/api/internal/job-complete', headers=HEADERS, timeout=60, json={'jobId': jid, 'sessionId': SESSION_ID, 'imageBase64': img_b64_small, 'seed': seed}).raise_for_status()\n",
    "                else: raise http_err\n",
    "        except Exception as e:\n",
    "            print(f' ❌ {e}')\n",
    "            try: requests.post(f'{WEB_URL}/api/internal/job-failed', headers=HEADERS, timeout=10, json={'jobId': jid, 'sessionId': SESSION_ID, 'errorMessage': str(e)})\n",
    "            except Exception: pass\n",
    "except KeyboardInterrupt:\n",
    "    print('\\n🛑 Detenido.')\n",
    "finally:\n",
    "    try: requests.post(f'{WEB_URL}/api/internal/session-end', headers=HEADERS, timeout=5, json={'sessionId': SESSION_ID})\n",
    "    except Exception: pass\n",
    "    if cf_proc.poll() is None: cf_proc.terminate()"
   ]
  }
